#!/usr/bin/env python3
"""
Nexus Control Panel CLI
Unified command & control interface for the entire Nexus ecosystem.

Supports --json for machine-readable output on supported commands.
"""

import argparse
import subprocess
import sys
import shutil
import json
from datetime import datetime, timezone

VERSION = "0.3.0-json"


def run_command(cmd, dry_run=False, capture_output=True):
    if dry_run:
        return {"dry_run": True, "command": " ".join(cmd)}
    try:
        result = subprocess.run(cmd, capture_output=capture_output, text=True, check=False)
        return result.stdout.strip() + ("\n" + result.stderr.strip() if result.stderr else "")
    except FileNotFoundError:
        return f"[ERROR] Command not found: {cmd[0]}"


def get_yggdrasil_data():
    data = {}
    if shutil.which("yggdrasilctl"):
        self_raw = run_command(["yggdrasilctl", "getSelf"])
        peers_raw = run_command(["yggdrasilctl", "getPeers"])
        data["self"] = self_raw
        data["peers"] = peers_raw
        data["available"] = True
    else:
        data["available"] = False
        data["error"] = "yggdrasilctl not found"
    return data


def get_docker_services(filter_name="nexus|yggdrasil|tenda"):
    if not shutil.which("docker"):
        return {"available": False, "error": "docker not found"}
    try:
        output = subprocess.check_output(
            ["docker", "ps", "--filter", f"name={filter_name}",
             "--format", "{{.Names}}\t{{.Status}}\t{{.Ports}}"],
            text=True
        ).strip()
        services = []
        for line in output.splitlines():
            parts = line.split("\t")
            if len(parts) >= 2:
                services.append({
                    "name": parts[0],
                    "status": parts[1],
                    "ports": parts[2] if len(parts) > 2 else ""
                })
        return {"available": True, "services": services}
    except Exception as e:
        return {"available": False, "error": str(e)}


def cmd_mesh_status(args):
    if args.json:
        result = {
            "command": "mesh status",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "node_filter": args.node,
            "yggdrasil": get_yggdrasil_data(),
            "docker": get_docker_services(),
        }
        print(json.dumps(result, indent=2))
        return

    # Human readable output (existing)
    print("=== NEXUS MESH STATUS ===")
    print(f"Node filter: {args.node}")
    print()

    if shutil.which("yggdrasilctl"):
        print("-- Yggdrasil --")
        print(run_command(["yggdrasilctl", "getSelf"]))
        print(run_command(["yggdrasilctl", "getPeers"]))
    else:
        print("[WARN] yggdrasilctl not found in PATH")

    if shutil.which("docker"):
        print("-- Docker Mesh Services --")
        docker_out = run_command([
            "docker", "ps",
            "--filter", "name=nexus|yggdrasil|tenda",
            "--format", "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
        ])
        print(docker_out if docker_out.strip() else "No matching containers running.")
    else:
        print("[INFO] docker not found in PATH")

    print("\n[INFO] Use --json for machine-readable output.")


def cmd_system_status(args):
    if args.json:
        result = {
            "command": "system status",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "host": {
                "uname": run_command(["uname", "-a"]),
                "uptime": run_command(["uptime"]),
                "disk": run_command(["df", "-h"])
            },
            "docker": get_docker_services(filter_name=".*")
        }
        print(json.dumps(result, indent=2))
        return

    # Human readable
    print("=== NEXUS SYSTEM STATUS ===")
    print(f"Timestamp: {datetime.now().isoformat(timespec='seconds')}")
    print()
    print("-- Host --")
    print(run_command(["uname", "-a"]))
    print(run_command(["uptime"]))
    print(run_command(["df", "-h"]))

    if shutil.which("docker"):
        print("-- Docker --")
        print(run_command(["docker", "ps", "--format", "table {{.Names}}\t{{.Status}}"]))

    print("\n[INFO] Use --json for structured output.")


def cmd_mesh_restart(args):
    if args.json:
        print(json.dumps({
            "command": "mesh restart",
            "service": args.service,
            "dry_run": args.dry_run,
            "status": "not_yet_implemented"
        }, indent=2))
        return

    # existing human logic...
    print("=== MESH RESTART ===")
    if not args.force:
        confirm = input(f"Restart mesh service '{args.service}'? [y/N]: ").strip().lower()
        if confirm != "y":
            print("Aborted.")
            return
    print(f"Restarting {args.service}... (placeholder)")


def cmd_generic_placeholder(category, action, args):
    if args.json:
        print(json.dumps({
            "command": f"{category} {action}",
            "status": "not_implemented",
            "message": f"{category} {action} is planned for Phase 2/3."
        }, indent=2))
        return

    print(f"[{category.upper()}] {action} is not yet fully implemented.")
    print("See CONTROL-COMMANDS.md for specification.")


def main():
    parser = argparse.ArgumentParser(
        prog="nexus-ctl",
        description="Nexus Control Panel - Unified CLI for the Nexus ecosystem.",
        epilog="Supports --json for scripting and agent integration."
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true", help="Output in JSON format (where supported)")
    parser.add_argument("--verbose", "-v", action="store_true")

    subparsers = parser.add_subparsers(dest="category", required=True)

    # mesh
    mesh_p = subparsers.add_parser("mesh")
    mesh_p.add_argument("action", choices=["status", "restart", "peer", "config", "monitor", "privacy", "qnet"])
    mesh_p.add_argument("--node", default="all")
    mesh_p.add_argument("--service", default="yggdrasil")
    mesh_p.add_argument("--force", action="store_true")
    mesh_p.set_defaults(func=lambda a: cmd_mesh_status(a) if a.action == "status" else 
                                   cmd_mesh_restart(a) if a.action == "restart" else 
                                   cmd_generic_placeholder("mesh", a.action, a))

    # agents
    agents_p = subparsers.add_parser("agents")
    agents_p.add_argument("action", choices=["list", "deploy", "scale", "introspect", "improve", "assign", "log"])
    agents_p.add_argument("--swarm")
    agents_p.set_defaults(func=lambda a: cmd_generic_placeholder("agents", a.action, a))

    # blockchain
    blockchain_p = subparsers.add_parser("blockchain")
    blockchain_p.add_argument("action", choices=["status", "tx", "arbitrage", "qnet", "rune", "monitor"])
    blockchain_p.add_argument("--coin", default="xcoin", choices=["xcoin", "qcoin"])
    blockchain_p.set_defaults(func=lambda a: cmd_generic_placeholder("blockchain", a.action, a))

    # hardware
    hardware_p = subparsers.add_parser("hardware")
    hardware_p.add_argument("action", choices=["status", "control", "flash", "calibrate", "grok-launcher", "monitor"])
    hardware_p.add_argument("--device")
    hardware_p.set_defaults(func=lambda a: cmd_generic_placeholder("hardware", a.action, a))

    # system
    system_p = subparsers.add_parser("system")
    system_p.add_argument("action", choices=["status", "logs", "auth", "backup", "privacy-audit", "orchestrate"])
    system_p.set_defaults(func=lambda a: cmd_system_status(a) if a.action == "status" else 
                                   cmd_generic_placeholder("system", a.action, a))

    args = parser.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()