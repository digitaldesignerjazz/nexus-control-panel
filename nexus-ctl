#!/usr/bin/env python3
"""
Nexus Control Panel CLI v0.4.0
Improved mesh status with better output and richer JSON.
"""

import argparse
import subprocess
import sys
import shutil
import json
import re
from datetime import datetime, timezone

VERSION = "0.4.0-mesh-status"


def run_command(cmd, dry_run=False, capture_output=True):
    if dry_run:
        return {"dry_run": True, "command": " ".join(cmd)}
    try:
        result = subprocess.run(cmd, capture_output=capture_output, text=True, check=False)
        return (result.stdout or "") + (result.stderr or "")
    except FileNotFoundError:
        return f"[ERROR] {cmd[0]} not found"


def parse_yggdrasil_self(raw_output):
    """Extract key fields from yggdrasilctl getSelf output."""
    data = {
        "address": None,
        "subnet": None,
        "public_key": None,
        "coords": None,
        "mtu": None
    }
    if not raw_output or "ERROR" in raw_output:
        return data

    lines = raw_output.strip().splitlines()
    for line in lines:
        line = line.strip()
        if line.startswith("IPv6 address:"):
            data["address"] = line.split(":", 1)[1].strip()
        elif line.startswith("IPv6 subnet:"):
            data["subnet"] = line.split(":", 1)[1].strip()
        elif line.startswith("Public key:"):
            data["public_key"] = line.split(":", 1)[1].strip()
        elif line.startswith("Coords:"):
            data["coords"] = line.split(":", 1)[1].strip()
        elif line.startswith("MTU:"):
            data["mtu"] = line.split(":", 1)[1].strip()
    return data


def get_yggdrasil_summary():
    if not shutil.which("yggdrasilctl"):
        return {"available": False, "error": "yggdrasilctl not found"}

    self_raw = run_command(["yggdrasilctl", "getSelf"])
    peers_raw = run_command(["yggdrasilctl", "getPeers"])

    parsed = parse_yggdrasil_self(self_raw)

    # Count peers
    peer_count = 0
    if peers_raw and "ERROR" not in peers_raw:
        peer_count = len([l for l in peers_raw.splitlines() if l.strip() and not l.startswith("-")])

    return {
        "available": True,
        "self": parsed,
        "peer_count": peer_count,
        "raw_self": self_raw.strip(),
        "raw_peers": peers_raw.strip()[:2000]  # limit size
    }


def get_docker_mesh_services():
    if not shutil.which("docker"):
        return {"available": False, "error": "docker not found"}

    try:
        output = subprocess.check_output(
            ["docker", "ps",
             "--filter", "name=nexus|yggdrasil|tenda|nova",
             "--format", "{{.Names}}\t{{.Status}}\t{{.Ports}}"],
            text=True
        ).strip()

        services = []
        for line in output.splitlines():
            parts = [p.strip() for p in line.split("\t")]
            if len(parts) >= 2:
                services.append({
                    "name": parts[0],
                    "status": parts[1],
                    "ports": parts[2] if len(parts) > 2 else ""
                })
        return {"available": True, "count": len(services), "services": services}
    except Exception as e:
        return {"available": False, "error": str(e)}


def cmd_mesh_status(args):
    ygg = get_yggdrasil_summary()
    docker = get_docker_mesh_services()

    if args.json:
        result = {
            "command": "mesh status",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "node_filter": getattr(args, "node", "all"),
            "yggdrasil": ygg,
            "docker": docker,
            "overall_status": "healthy" if ygg.get("available") else "degraded"
        }
        print(json.dumps(result, indent=2))
        return

    # Human-readable output
    print("=== NEXUS MESH STATUS ===")
    print(f"Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print()

    # Yggdrasil section
    if ygg.get("available"):
        print("-- Yggdrasil --")
        self_info = ygg.get("self", {})
        if self_info.get("address"):
            print(f"  Address   : {self_info['address']}")
        if self_info.get("subnet"):
            print(f"  Subnet    : {self_info['subnet']}")
        if self_info.get("coords"):
            print(f"  Coords    : {self_info['coords']}")
        print(f"  Peers     : {ygg.get('peer_count', 0)}")
        print()
    else:
        print("-- Yggdrasil --")
        print("  Not available (yggdrasilctl not found or not running)")
        print()

    # Docker section
    if docker.get("available"):
        print("-- Docker Services --")
        if docker.get("count", 0) > 0:
            for svc in docker["services"]:
                print(f"  {svc['name']:<25} {svc['status']}")
        else:
            print("  No matching mesh-related containers running.")
        print()
    else:
        print("-- Docker --")
        print("  docker not available")
        print()

    print("[Tip] Use --json for machine-readable output")
    print("[Tip] nexus-ctl mesh restart --service yggdrasil --dry-run")


def cmd_system_status(args):
    if args.json:
        result = {
            "command": "system status",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "host": {
                "uname": run_command(["uname", "-a"]).strip(),
                "uptime": run_command(["uptime"]).strip(),
                "disk": run_command(["df", "-h"]).strip()
            },
            "docker": get_docker_mesh_services(filter_name=".*")
        }
        print(json.dumps(result, indent=2))
        return

    print("=== NEXUS SYSTEM STATUS ===")
    print(f"Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print()
    print("-- Host --")
    print(run_command(["uname", "-a"]).strip())
    print(run_command(["uptime"]).strip())
    print()
    print(run_command(["df", "-h"]).strip())

    docker = get_docker_mesh_services(filter_name=".*")
    if docker.get("available") and docker.get("count", 0) > 0:
        print("\n-- Docker --")
        for svc in docker["services"]:
            print(f"  {svc['name']:<30} {svc['status']}")


def cmd_mesh_restart(args):
    if args.json:
        print(json.dumps({
            "command": "mesh restart",
            "service": args.service,
            "dry_run": args.dry_run,
            "status": "placeholder"
        }, indent=2))
        return

    print(f"[mesh] Restarting {args.service}... (not yet fully implemented)")


def cmd_generic_placeholder(category, action, args):
    if args.json:
        print(json.dumps({
            "command": f"{category} {action}",
            "status": "not_implemented"
        }, indent=2))
        return
    print(f"[{category}] {action} is planned for later phases.")


def main():
    parser = argparse.ArgumentParser(
        prog="nexus-ctl",
        description="Nexus Control Panel CLI",
        epilog="Use --json for structured output. Tab completion supported."
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true", help="Output JSON (supported on mesh/system status)")
    parser.add_argument("--verbose", "-v", action="store_true")

    subparsers = parser.add_subparsers(dest="category", required=True)

    # mesh
    mesh_p = subparsers.add_parser("mesh")
    mesh_p.add_argument("action", choices=["status", "restart", "peer", "config", "monitor", "privacy", "qnet"])
    mesh_p.add_argument("--node", default="all")
    mesh_p.add_argument("--service", default="yggdrasil")
    mesh_p.add_argument("--force", action="store_true")
    mesh_p.set_defaults(func=lambda a: cmd_mesh_status(a) if a.action == "status" else 
                                   cmd_mesh_restart(a) if a.action == "restart" else 
                                   cmd_generic_placeholder("mesh", a.action, a))

    # agents
    agents_p = subparsers.add_parser("agents")
    agents_p.add_argument("action", choices=["list", "deploy", "scale", "introspect", "improve", "assign", "log"])
    agents_p.set_defaults(func=lambda a: cmd_generic_placeholder("agents", a.action, a))

    # blockchain
    blockchain_p = subparsers.add_parser("blockchain")
    blockchain_p.add_argument("action", choices=["status", "tx", "arbitrage", "qnet", "rune", "monitor"])
    blockchain_p.add_argument("--coin", default="xcoin")
    blockchain_p.set_defaults(func=lambda a: cmd_generic_placeholder("blockchain", a.action, a))

    # hardware
    hardware_p = subparsers.add_parser("hardware")
    hardware_p.add_argument("action", choices=["status", "control", "flash", "calibrate", "grok-launcher", "monitor"])
    hardware_p.add_argument("--device")
    hardware_p.set_defaults(func=lambda a: cmd_generic_placeholder("hardware", a.action, a))

    # system
    system_p = subparsers.add_parser("system")
    system_p.add_argument("action", choices=["status", "logs", "auth", "backup", "privacy-audit", "orchestrate"])
    system_p.set_defaults(func=lambda a: cmd_system_status(a) if a.action == "status" else 
                                   cmd_generic_placeholder("system", a.action, a))

    args = parser.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()